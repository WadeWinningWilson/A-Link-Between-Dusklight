*.rel
*.elf
*.o
*.map
*.MAP

# Save files
*.raw
*.gci

# Build files
build/
.ninja_*
build.ninja

# decompctx output
ctx.*
*.ctx

# Generated configs
objdiff.json
compile_commands.json

# Miscellaneous
*.exe
*.zip

# CoNavigate dev traces (never commit session logs)
**/conavigate/
conavigate_session.log

# CoNavigate / drive dev sources (local automation only — see local_dev_backup/)
build_conavigate.bat
docs/conavigate.md
include/dusk/conavigate.h
src/dusk/conavigate.cpp
include/dusk/drive.h
src/dusk/drive.cpp

# Local automation / CoNavigate backup (move off-machine manually)
local_dev_backup/

# ALBW mod local backups — keep these local, never commit
albw_backup_*/

# ALBW temp debug dumps from dev sessions
albw_*_debug.txt

# Local-only captured diagnostic dumps (preserved for reference, never commit)
Diagnostic files/

# Agent build logs
build_stdout.txt
build_stderr.txt
build_stdout_*.txt
build_stderr_*.txt
golden_err*.txt

# Local dev rebuild helpers (see build_run.bat / rebuild.bat in repo)
clean_rebuild.bat
reconfigure_build.bat

# Cursor-export mockups (machine-specific paths; see docs/mockups/README.md)
docs/mockups/c__Users_*

# MacOS
.DS_Store

# direnv / nix
.direnv/
.envrc

# ISOs
*.iso

*.ini
*.controller
pipeline_cache.bin

extract

